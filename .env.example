# Copy to .env for local dev. Compose injects service-network URLs itself; these are for
# host-side tools (pytest uses ports 55432 / 56379 against the same containers).

ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FORMAT=json

# Runtime app role (RLS enforced) + admin role (migrations). Inside compose network:
DATABASE_URL=postgresql+psycopg://pulse_app:pulse_app@db:5432/pulse
ADMIN_DATABASE_URL=postgresql+psycopg://pulse:pulse@db:5432/pulse
REDIS_URL=redis://redis:6379/0

FRONTEND_ORIGIN=http://localhost:5173
SESSION_SECRET=dev-secret-change-me

# Optional integrations (unset = feature disabled / dev fallback):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=whsec_test
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_TEAM=
# RESEND_API_KEY=
# SENTRY_DSN=
